rules_version = '2';

service cloud.firestore {
	match /databases/{database}/documents {
		function isSignedIn() {
			return request.auth != null;
		}

		function isOwner(userId) {
			return isSignedIn() && request.auth.uid == userId;
		}

		function validHexColor(value) {
			return value is string && value.matches('^#[0-9A-Fa-f]{6}$');
		}

		function validPeriodId(value) {
			return value is string && value.matches('^\\d{4}-\\d{2}$');
		}

		function validDateLabel(value) {
			return value is string && value.matches('^\\d{4}-\\d{2}-\\d{2}$');
		}

		function validOptionalDateLabel(value) {
			return value == '' || validDateLabel(value);
		}

		function validPositiveAmount(value) {
			return value is number && value > 0;
		}

		function validAmount(value) {
			return value is number;
		}

		function validPreferencesDoc(userId) {
			return request.resource.data.keys().hasOnly([
				'uid',
				'darkMode',
				'themeColor',
				'selectedYear',
				'selectedMonth',
				'updatedAt'
			])
			&& request.resource.data.keys().hasAll([
				'uid',
				'updatedAt'
			])
			&& request.resource.data.uid is string
			&& request.resource.data.uid == userId
			&& (!('darkMode' in request.resource.data) || request.resource.data.darkMode is bool)
			&& (!('themeColor' in request.resource.data) || validHexColor(request.resource.data.themeColor))
			&& (!('selectedYear' in request.resource.data)
				|| request.resource.data.selectedYear == null
				|| (
					request.resource.data.selectedYear is number
					&& request.resource.data.selectedYear >= 2000
					&& request.resource.data.selectedYear <= 2100
				))
			&& (!('selectedMonth' in request.resource.data)
				|| request.resource.data.selectedMonth == null
				|| (
					request.resource.data.selectedMonth is number
					&& request.resource.data.selectedMonth >= 1
					&& request.resource.data.selectedMonth <= 12
				))
			&& request.resource.data.updatedAt is timestamp;
		}

		function validPeriodDoc() {
			return request.resource.data.keys().hasOnly([
				'year',
				'month',
				'label',
				'createdAt',
				'updatedAt'
			])
			&& request.resource.data.keys().hasAll([
				'year',
				'month',
				'label',
				'createdAt',
				'updatedAt'
			])
			&& request.resource.data.year is number
			&& request.resource.data.year >= 2000
			&& request.resource.data.year <= 2100
			&& request.resource.data.month is number
			&& request.resource.data.month >= 1
			&& request.resource.data.month <= 12
			&& request.resource.data.label is string
			&& request.resource.data.label.size() > 0
			&& request.resource.data.label.size() <= 80
			&& request.resource.data.createdAt is timestamp
			&& request.resource.data.updatedAt is timestamp;
		}

		function validAssetDoc() {
			return request.resource.data.keys().hasOnly([
				'name',
				'startDate',
				'initialValue',
				'institution',
				'category',
				'color',
				'isActive',
				'createdAt',
				'updatedAt'
			])
			&& request.resource.data.keys().hasAll([
				'name',
				'startDate',
				'initialValue',
				'institution',
				'category',
				'color',
				'isActive',
				'createdAt',
				'updatedAt'
			])
			&& request.resource.data.name is string
			&& request.resource.data.name.size() > 0
			&& request.resource.data.name.size() <= 120
			&& validDateLabel(request.resource.data.startDate)
			&& validPositiveAmount(request.resource.data.initialValue)
			&& request.resource.data.institution is string
			&& request.resource.data.institution.size() <= 120
			&& request.resource.data.category is string
			&& request.resource.data.category.size() <= 80
			&& validHexColor(request.resource.data.color)
			&& request.resource.data.isActive is bool
			&& request.resource.data.createdAt is timestamp
			&& request.resource.data.updatedAt is timestamp;
		}

		function validAssetMonthlyStateDoc() {
			return request.resource.data.keys().hasOnly([
				'assetId',
				'periodId',
				'openingCapitalInvested',
				'currentCapitalInvested',
				'openingLiquidBalance',
				'currentLiquidBalance',
				'openingGrossBalance',
				'currentGrossBalance',
				'monthNetIncome',
				'monthGrossIncome',
				'monthContributions',
				'monthNormalWithdrawals',
				'monthExtraWithdrawals',
				'lastReadingDate',
				'createdAt',
				'updatedAt'
			])
			&& request.resource.data.keys().hasAll([
				'assetId',
				'periodId',
				'openingCapitalInvested',
				'currentCapitalInvested',
				'openingLiquidBalance',
				'currentLiquidBalance',
				'openingGrossBalance',
				'currentGrossBalance',
				'monthNetIncome',
				'monthGrossIncome',
				'monthContributions',
				'monthNormalWithdrawals',
				'monthExtraWithdrawals',
				'lastReadingDate',
				'createdAt',
				'updatedAt'
			])
			&& request.resource.data.assetId is string
			&& request.resource.data.assetId.size() > 0
			&& validPeriodId(request.resource.data.periodId)
			&& validAmount(request.resource.data.openingCapitalInvested)
			&& validAmount(request.resource.data.currentCapitalInvested)
			&& validAmount(request.resource.data.openingLiquidBalance)
			&& validAmount(request.resource.data.currentLiquidBalance)
			&& validAmount(request.resource.data.openingGrossBalance)
			&& validAmount(request.resource.data.currentGrossBalance)
			&& validAmount(request.resource.data.monthNetIncome)
			&& validAmount(request.resource.data.monthGrossIncome)
			&& validAmount(request.resource.data.monthContributions)
			&& validAmount(request.resource.data.monthNormalWithdrawals)
			&& validAmount(request.resource.data.monthExtraWithdrawals)
			&& validOptionalDateLabel(request.resource.data.lastReadingDate)
			&& request.resource.data.createdAt is timestamp
			&& request.resource.data.updatedAt is timestamp;
		}

		function validTransactionDoc() {
			return request.resource.data.keys().hasOnly([
				'assetId',
				'periodId',
				'type',
				'amount',
				'note',
				'transactionDate',
				'source',
				'createdAt',
				'updatedAt'
			])
			&& request.resource.data.keys().hasAll([
				'assetId',
				'periodId',
				'type',
				'amount',
				'note',
				'transactionDate',
				'source',
				'createdAt',
				'updatedAt'
			])
			&& request.resource.data.assetId is string
			&& request.resource.data.assetId.size() > 0
			&& validPeriodId(request.resource.data.periodId)
			&& request.resource.data.type in ['contribution', 'withdrawal', 'extraWithdrawal']
			&& validPositiveAmount(request.resource.data.amount)
			&& request.resource.data.note is string
			&& request.resource.data.note.size() > 0
			&& request.resource.data.note.size() <= 200
			&& validDateLabel(request.resource.data.transactionDate)
			&& request.resource.data.source is string
			&& request.resource.data.source.size() > 0
			&& request.resource.data.source.size() <= 40
			&& request.resource.data.createdAt is timestamp
			&& request.resource.data.updatedAt is timestamp;
		}

		function validDailyReadingDoc() {
			return request.resource.data.keys().hasOnly([
				'assetId',
				'periodId',
				'liquidBalance',
				'grossBalance',
				'readingDate',
				'source',
				'createdAt',
				'updatedAt'
			])
			&& request.resource.data.keys().hasAll([
				'assetId',
				'periodId',
				'liquidBalance',
				'grossBalance',
				'readingDate',
				'source',
				'createdAt',
				'updatedAt'
			])
			&& request.resource.data.assetId is string
			&& request.resource.data.assetId.size() > 0
			&& validPeriodId(request.resource.data.periodId)
			&& validPositiveAmount(request.resource.data.liquidBalance)
			&& validPositiveAmount(request.resource.data.grossBalance)
			&& validDateLabel(request.resource.data.readingDate)
			&& request.resource.data.source is string
			&& request.resource.data.source.size() > 0
			&& request.resource.data.source.size() <= 40
			&& request.resource.data.createdAt is timestamp
			&& request.resource.data.updatedAt is timestamp;
		}

		match /users/{userId} {
			allow read: if isOwner(userId);
			allow write: if false;

			match /configs/preferences {
				allow read: if isOwner(userId);
				allow create, update: if isOwner(userId) && validPreferencesDoc(userId);
				allow delete: if false;
			}

			match /periods/{periodId} {
				allow read, delete: if isOwner(userId);
				allow create, update: if isOwner(userId) && validPeriodDoc();
			}

			match /assets/{assetId} {
				allow read, delete: if isOwner(userId);
				allow create, update: if isOwner(userId) && validAssetDoc();
			}

			match /assetMonthlyStates/{monthlyStateId} {
				allow read, delete: if isOwner(userId);
				allow create, update: if isOwner(userId) && validAssetMonthlyStateDoc();
			}

			match /transactions/{transactionId} {
				allow read, delete: if isOwner(userId);
				allow create, update: if isOwner(userId) && validTransactionDoc();
			}

			match /dailyReadings/{dailyReadingId} {
				allow read, delete: if isOwner(userId);
				allow create, update: if isOwner(userId) && validDailyReadingDoc();
			}
		}
	}
}
